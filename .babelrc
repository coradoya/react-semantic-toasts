{
    "presets": ["@babel/preset-env", "@babel/preset-react"],
    "plugins": [
        ["babel-plugin-react-compiler", { "target": "18" }],
        "@babel/plugin-proposal-object-rest-spread",
        "@babel/plugin-proposal-class-properties",
        "@babel/plugin-transform-async-to-generator",
        [
            "module-resolver",
            {
                "root": ["./lib"]
            }
        ]
    ],
    "retainLines": true
}
