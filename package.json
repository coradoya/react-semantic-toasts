{
    "name": "@coradoya/react-semantic-toasts",
    "version": "0.7.0",
    "description": "React Semantic UI alerts library",
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "files": [
        "build",
        "styles",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "keywords": [
        "react",
        "semantic ui",
        "toast",
        "alerts"
    ],
    "scripts": {
        "build": "babel lib -d build",
        "build:watch": "babel lib -w -d build",
        "eslint": "eslint lib/**/*.jsx lib/**/*.js",
        "eslint-check": "eslint --print-config .eslintrc.json | eslint-config-prettier-check",
        "prepack": "copyfiles -u 1 lib/index.d.ts build",
        "test": "jest",
        "test:compiled": "npm run build && jest --testPathPattern=compiled"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/coradoya/react-semantic-toasts.git"
    },
    "author": "<Academia de Código_>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/coradoya/react-semantic-toasts/issues"
    },
    "devDependencies": {
        "@babel/cli": "^7.16.0",
        "@babel/core": "^7.16.0",
        "@babel/eslint-parser": "^7.29.7",
        "@babel/plugin-proposal-class-properties": "^7.16.0",
        "@babel/plugin-proposal-object-rest-spread": "^7.16.0",
        "@babel/plugin-transform-async-to-generator": "^7.16.0",
        "@babel/preset-env": "^7.16.4",
        "@babel/preset-react": "^7.16.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "babel-jest": "^29.7.0",
        "babel-plugin-module-resolver": "^4.1.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "copyfiles": "^2.4.1",
        "eslint": "^8.3.0",
        "eslint-config-airbnb": "^19.0.1",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-import": "^2.25.3",
        "eslint-plugin-jsx-a11y": "^6.5.1",
        "eslint-plugin-react": "^7.27.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "prettier-eslint": "^13.0.0",
        "prop-types": "^15.7.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "semantic-ui-css": "^2.5.0",
        "semantic-ui-react": "^2.1.5"
    },
    "peerDependencies": {
        "prop-types": "^15.7.2",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "semantic-ui-react": "^2.1.3"
    },
    "dependencies": {
        "react-compiler-runtime": "^1.0.0"
    },
    "overrides": {
        "eslint-config-airbnb": {
            "eslint-plugin-react-hooks": "$eslint-plugin-react-hooks"
        }
    }
}
